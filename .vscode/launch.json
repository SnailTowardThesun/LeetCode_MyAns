{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++: Debug Tests",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/cplusplus/build/tests",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/cplusplus/build",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "C++: Build"
        },
        {
            "name": "C++: Debug Current File",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/cplusplus/build/tests",
            "args": ["--gtest_filter=*"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/cplusplus",
            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "preLaunchTask": "C++: Build"
        },
        {
            "name": "Rust: Debug Tests",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": ["test", "--no-run", "--lib"],
                "filter": {
                    "name": "ans",
                    "kind": "lib"
                }
            },
            "args": [],
            "cwd": "${workspaceFolder}/rust"
        }
    ]
}
